rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() in ['admin'];
    }

    function isModerator() {
      return isAuthenticated() && getUserRole() in ['moderator', 'admin'];
    }

    function isNotRateLimited(collection, maxPer5Min) {
      let recent = collection
        .where("authorId", "==", request.auth.uid)
        .where("createdAt", ">=", request.time - duration.value(5, 'm'));
      return recent.size() < maxPer5Min;
    }

    // ── USERS Collection ──
    match /users/{userId} {
      allow read: if true;

      // Authenticated users can create their own profile
      allow create: if isOwner(userId) &&
        request.resource.data.displayName is string &&
        request.resource.data.email == null || request.resource.data.email is string;

      // Users can update their own profile (but not role — admins do that)
      allow update: if isOwner(userId) &&
        (request.resource.data.role == resource.data.role ||
         !request.resource.data.keys().hasAny(['role']));

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ── CATEGORIES Collection ──
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── THREADS Collection ──
    match /threads/{threadId} {
      allow read: if true;

      // Authenticated users (including anonymous) can create threads
      allow create: if isAuthenticated() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 200 &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.categoryId is string &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.authorName is string;

      // Thread authors, moderators, and admins can update
      allow update: if isAuthenticated() &&
        (isOwner(resource.data.authorId) || isModerator());

      // Only moderators and admins can delete threads
      allow delete: if isModerator();
    }

    // ── REPLIES Collection ──
    match /replies/{replyId} {
      allow read: if true;

      // Authenticated users (including anonymous) can create replies
      allow create: if isAuthenticated() &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 5000 &&
        request.resource.data.threadId is string &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.authorName is string;

      // Reply authors, moderators, and admins can update
      allow update: if isAuthenticated() &&
        (isOwner(resource.data.authorId) || isModerator());

      // Reply authors, moderators, and admins can delete
      allow delete: if isAuthenticated() &&
        (isOwner(resource.data.authorId) || isModerator());
    }

    // ── REPORTS Collection (Moderation) ──
    match /reports/{reportId} {
      // Only moderators and admins can read reports
      allow read: if isModerator();

      // Any authenticated user can submit a report
      allow create: if isAuthenticated() &&
        request.resource.data.targetId is string &&
        request.resource.data.targetType is string &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() > 0 &&
        request.resource.data.reason.size() <= 500 &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.status == 'pending';

      // Only moderators and admins can update report status
      allow update: if isModerator() &&
        request.resource.data.keys().hasOnly(['status', 'moderatorNote']);

      // No one can delete reports (audit trail)
      allow delete: if false;
    }

  }
}
